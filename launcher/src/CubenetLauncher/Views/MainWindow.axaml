<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CubenetLauncher.ViewModels"
        xmlns:views="using:CubenetLauncher.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
        x:Class="CubenetLauncher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Cubenet Launcher"
        Width="1280" Height="720"
        MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowDecorations="None"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        TransparencyLevelHint="AcrylicBlur"
        TransparencyBackgroundFallback="#0E0E0E">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Border CornerRadius="8" ClipToBounds="True">
        <Panel>
            <ExperimentalAcrylicBorder IsHitTestVisible="False">
                <ExperimentalAcrylicBorder.Material>
                    <ExperimentalAcrylicMaterial
                        BackgroundSource="Digger"
                        MaterialOpacity="0.85"
                        TintColor="Black"
                        TintOpacity="0.9"/>
                </ExperimentalAcrylicBorder.Material>
            </ExperimentalAcrylicBorder>

            <!-- Overlay -->
            <Rectangle Fill="#0A000000"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0"
                        Background="#0A0D0D"
                        Padding="0,20"
                        BoxShadow="2 0 15 #40000000">
                    <Grid RowDefinitions="Auto, *, Auto"
                          Width="80">

                        <!-- Logo -->
                        <Border Grid.Row="0"
                                Background="#008C45"
                                CornerRadius="12"
                                Width="40" Height="40"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,30">
                            <TextBlock Text="C"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="#ffffff"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Nav buttons -->
                        <StackPanel Grid.Row="1"
                                    Spacing="10"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <Button Command="{Binding GoToHomeCommand}"
                                    Width="50" Height="50"
                                    CornerRadius="25"
                                    Background="{Binding HomeButtonBg}"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip.Tip="Главная">
                                <TextBlock Text="🏠" FontSize="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>

                            <Button Width="50" Height="50"
                                    CornerRadius="25"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip.Tip="Сборки">
                                <TextBlock Text="📦" FontSize="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>

                            <Button Width="50" Height="50"
                                    CornerRadius="25"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip.Tip="Моды">
                                <TextBlock Text="🔧" FontSize="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>

                            <Button Command="{Binding GoToSettingsCommand}"
                                    Width="50" Height="50"
                                    CornerRadius="25"
                                    Background="{Binding SettingsButtonBg}"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip.Tip="Настройки">
                                <TextBlock Text="⚙️" FontSize="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>

                        <!-- Logout placeholder -->
                        <Button Grid.Row="2"
                                Width="50" Height="50"
                                CornerRadius="25"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Margin="0,0,0,10"
                                ToolTip.Tip="Выйти">
                            <TextBlock Text="🚪" FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Content -->
                <Border Grid.Column="1">
                    <ContentControl Content="{Binding CurrentPage}"
                                    Margin="0">
                        <ContentControl.DataTemplates>
                            <DataTemplate DataType="vm:HomeViewModel">
                                <views:HomeView/>
                            </DataTemplate>
                            <DataTemplate DataType="vm:SettingsViewModel">
                                <views:SettingsView/>
                            </DataTemplate>
                        </ContentControl.DataTemplates>
                    </ContentControl>
                </Border>
            </Grid>
        </Panel>
    </Border>
</Window>
