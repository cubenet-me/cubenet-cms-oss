<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CubenetLauncher.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1060" d:DesignHeight="720"
             x:Class="CubenetLauncher.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             Background="Transparent">

    <Grid>
        <ScrollViewer Padding="30">
            <StackPanel Spacing="8" MaxWidth="620" HorizontalAlignment="Left">

                <TextBlock Text="Настройки"
                           FontSize="28" FontWeight="Bold"
                           Foreground="#FFFFFF"
                           Margin="0,10,0,0"/>

                <TextBlock Text="Управляй параметрами запуска Minecraft"
                           FontSize="14"
                           Foreground="#969696"
                           Margin="0,-4,0,20"/>

                <!-- RAM Card -->
                <Border CornerRadius="20"
                        Padding="24"
                        BoxShadow="0 4 12 #20000000"
                        BorderBrush="#2E2E2E"
                        BorderThickness="1"
                        Background="#111111">
                    <StackPanel Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="💾" FontSize="22"/>
                            <TextBlock Text="Оперативная память"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="#FFFFFF"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Рекомендуется 2048–4096 MB"
                                   FontSize="12"
                                   Foreground="#969696"
                                   Margin="32,0,0,0"/>

                        <Border Background="#151515"
                                BorderBrush="#212121"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="16,6"
                                Margin="32,0,0,0">
                            <Grid ColumnDefinitions="*, 80">
                                <Slider Grid.Column="0"
                                        Minimum="512"
                                        Maximum="16384"
                                        Value="{Binding RamMb}"
                                        Margin="0,0,16,0"/>
                                <Border Grid.Column="1"
                                        CornerRadius="8"
                                        Background="#0E0E0E"
                                        Padding="8,4">
                                    <TextBlock Text="{Binding RamMb}"
                                               Foreground="#FFFFFF"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Java Path Card -->
                <Border CornerRadius="20"
                        Padding="24"
                        BoxShadow="0 4 12 #20000000"
                        BorderBrush="#2E2E2E"
                        BorderThickness="1"
                        Background="#111111">
                    <StackPanel Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="☕" FontSize="22"/>
                            <TextBlock Text="Путь к Java"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="#FFFFFF"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Оставь пустым для авто-поиска"
                                   FontSize="12"
                                   Foreground="#969696"
                                   Margin="32,0,0,0"/>
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10"
                              Margin="32,0,0,0">
                            <Border Grid.Column="0"
                                    Background="#151515"
                                    BorderBrush="#212121"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14,10">
                                <TextBlock Text="{Binding JavaPath}"
                                           Foreground="#969696"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>
                            <Button Grid.Column="1"
                                    Content="Обзор"
                                    Background="#151515"
                                    BorderBrush="#212121"
                                    BorderThickness="1"
                                    Foreground="#FFFFFF"
                                    FontWeight="SemiBold"
                                    CornerRadius="25"
                                    Padding="16,9"
                                    Click="BrowseJavaPath"
                                    Cursor="Hand"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Game Directory Card -->
                <Border CornerRadius="20"
                        Padding="24"
                        BoxShadow="0 4 12 #20000000"
                        BorderBrush="#2E2E2E"
                        BorderThickness="1"
                        Background="#111111">
                    <StackPanel Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="📁" FontSize="22"/>
                            <TextBlock Text="Игровая директория"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="#FFFFFF"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Папка с ассетами, модами и конфигами"
                                   FontSize="12"
                                   Foreground="#969696"
                                   Margin="32,0,0,0"/>
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10"
                              Margin="32,0,0,0">
                            <Border Grid.Column="0"
                                    Background="#151515"
                                    BorderBrush="#212121"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14,10">
                                <TextBlock Text="{Binding GameDirectory}"
                                           Foreground="#969696"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>
                            <Button Grid.Column="1"
                                    Content="Обзор"
                                    Background="#151515"
                                    BorderBrush="#212121"
                                    BorderThickness="1"
                                    Foreground="#FFFFFF"
                                    FontWeight="SemiBold"
                                    CornerRadius="25"
                                    Padding="16,9"
                                    Click="BrowseGameDir"
                                    Cursor="Hand"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Save Button -->
                <Button Content="Сохранить"
                        Command="{Binding SaveCommand}"
                        Background="#008C45"
                        Foreground="#FFFFFF"
                        FontSize="15" FontWeight="Bold"
                        CornerRadius="25"
                        Padding="36,12"
                        HorizontalAlignment="Left"
                        Margin="0,10,0,0"
                        Cursor="Hand"
                        BorderThickness="0"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
