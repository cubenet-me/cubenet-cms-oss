<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1060" d:DesignHeight="720"
             x:Class="CubenetLauncher.Views.HomeView">

    <ScrollViewer Padding="40">
        <StackPanel Spacing="24">

            <Border CornerRadius="16"
                    BoxShadow="0 8 30 #40000000"
                    Padding="40"
                    HorizontalAlignment="Stretch"
                    Height="200">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#6c63ff" Offset="0.0"/>
                        <GradientStop Color="#4a3fbf" Offset="0.5"/>
                        <GradientStop Color="#2a1f8a" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border CornerRadius="16" Background="#00000015">
                    <StackPanel VerticalAlignment="Center" Spacing="8">
                        <TextBlock Text="Добро пожаловать в Cubenet!"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#ffffff"/>
                        <TextBlock Text="Погрузись в мир модифицированного майнкрафта"
                                   FontSize="16"
                                   Foreground="#ddddff"/>
                    </StackPanel>
                </Border>
            </Border>

            <TextBlock Text="Последние сборки"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#ddddff"/>

            <WrapPanel>
                <Border CornerRadius="14"
                        Width="280" Height="200"
                        Margin="0,0,20,20"
                        BoxShadow="0 6 20 #30000000">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                            <GradientStop Color="#1e1e38" Offset="0.0"/>
                            <GradientStop Color="#16162a" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border CornerRadius="14" Background="#00000010">
                        <StackPanel VerticalAlignment="Bottom" Spacing="10" Margin="20">
                            <Border Background="#6c63ff"
                                    CornerRadius="6"
                                    Padding="10,4"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="1.21.4" FontSize="12" FontWeight="Bold" Foreground="#ffffff"/>
                            </Border>
                            <TextBlock Text="Vanilla" FontSize="20" FontWeight="Bold" Foreground="#ffffff"/>
                            <TextBlock Text="Чистый майнкрафт без модов" FontSize="12" Foreground="#7777aa"/>
                            <Border Background="#ffffff10"
                                    CornerRadius="8"
                                    Padding="12,8"
                                    HorizontalAlignment="Left"
                                    Margin="0,6,0,0">
                                <TextBlock Text="▶ Играть" FontSize="13" FontWeight="Bold" Foreground="#ddddff"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Border>

                <Border CornerRadius="14"
                        Width="280" Height="200"
                        Margin="0,0,20,20"
                        BoxShadow="0 6 20 #30000000">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                            <GradientStop Color="#1e1e38" Offset="0.0"/>
                            <GradientStop Color="#16162a" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border CornerRadius="14" Background="#00000010">
                        <StackPanel VerticalAlignment="Bottom" Spacing="10" Margin="20">
                            <Border Background="#4a3fbf"
                                    CornerRadius="6"
                                    Padding="10,4"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="1.20.1" FontSize="12" FontWeight="Bold" Foreground="#ffffff"/>
                            </Border>
                            <TextBlock Text="Modded" FontSize="20" FontWeight="Bold" Foreground="#ffffff"/>
                            <TextBlock Text="Fabric — 50+ модов" FontSize="12" Foreground="#7777aa"/>
                            <Border Background="#ffffff10"
                                    CornerRadius="8"
                                    Padding="12,8"
                                    HorizontalAlignment="Left"
                                    Margin="0,6,0,0">
                                <TextBlock Text="▶ Играть" FontSize="13" FontWeight="Bold" Foreground="#ddddff"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Border>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
