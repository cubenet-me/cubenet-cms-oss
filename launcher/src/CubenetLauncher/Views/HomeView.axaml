<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1060" d:DesignHeight="720"
             Background="Transparent"
             x:Class="CubenetLauncher.Views.HomeView">

    <Grid>
        <ScrollViewer Padding="30">
            <StackPanel Spacing="24" MaxWidth="800" HorizontalAlignment="Left">

                <!-- Greeting -->
                <TextBlock Text="Добро пожаловать в Cubenet!"
                           FontSize="28" FontWeight="Bold"
                           Foreground="#FFFFFF"
                           Margin="0,10,0,0"/>

                <TextBlock Text="Выбери сборку и начинай играть"
                           FontSize="14"
                           Foreground="#969696"
                           Margin="0,-12,0,0"/>

                <!-- Card 1 -->
                <Border CornerRadius="20"
                        Padding="24"
                        BoxShadow="0 4 12 #20000000"
                        BorderBrush="#2E2E2E"
                        BorderThickness="1"
                        Background="#111111">
                    <Grid ColumnDefinitions="*, Auto">
                        <StackPanel Spacing="12" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Background="#008C45"
                                        CornerRadius="6"
                                        Padding="10,4">
                                    <TextBlock Text="1.21.4" FontSize="12"
                                               FontWeight="Bold" Foreground="#FFFFFF"/>
                                </Border>
                                <Border Background="#2E2E2E"
                                        CornerRadius="6"
                                        Padding="10,4">
                                    <TextBlock Text="Vanilla" FontSize="12"
                                               FontWeight="SemiBold" Foreground="#969696"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Чистый майнкрафт"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="#FFFFFF"/>
                            <TextBlock Text="Без модов. Версия 1.21.4"
                                       FontSize="13"
                                       Foreground="#969696"/>
                            <Button Content="Играть"
                                    Background="#008C45"
                                    Foreground="#FFFFFF"
                                    FontWeight="Bold"
                                    CornerRadius="25"
                                    Padding="24,10"
                                    Margin="0,6,0,0"
                                    HorizontalAlignment="Left"
                                    Cursor="Hand"
                                    BorderThickness="0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Card 2 -->
                <Border CornerRadius="20"
                        Padding="24"
                        BoxShadow="0 4 12 #20000000"
                        BorderBrush="#2E2E2E"
                        BorderThickness="1"
                        Background="#111111">
                    <Grid ColumnDefinitions="*, Auto">
                        <StackPanel Spacing="12" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Background="#008C45"
                                        CornerRadius="6"
                                        Padding="10,4">
                                    <TextBlock Text="1.20.1" FontSize="12"
                                               FontWeight="Bold" Foreground="#FFFFFF"/>
                                </Border>
                                <Border Background="#2E2E2E"
                                        CornerRadius="6"
                                        Padding="10,4">
                                    <TextBlock Text="Fabric" FontSize="12"
                                               FontWeight="SemiBold" Foreground="#969696"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Modded"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="#FFFFFF"/>
                            <TextBlock Text="50+ модов на Fabric"
                                       FontSize="13"
                                       Foreground="#969696"/>
                            <Button Content="Играть"
                                    Background="#008C45"
                                    Foreground="#FFFFFF"
                                    FontWeight="Bold"
                                    CornerRadius="25"
                                    Padding="24,10"
                                    Margin="0,6,0,0"
                                    HorizontalAlignment="Left"
                                    Cursor="Hand"
                                    BorderThickness="0"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
