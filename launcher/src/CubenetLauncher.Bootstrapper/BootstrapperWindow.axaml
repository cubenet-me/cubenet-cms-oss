<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CubenetLauncher.Bootstrapper.BootstrapperWindow"
        Title="Cubenet Bootstrapper"
        Width="350" Height="200"
        WindowStartupLocation="CenterScreen"
        WindowDecorations="Default"
        Background="#1a1b2e"
        CanResize="False">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
        <TextBlock Text="CUBENET"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#6c63ff"
                   HorizontalAlignment="Center"/>

        <TextBlock x:Name="StatusText"
                   Text="Инициализация..."
                   FontSize="12"
                   Foreground="#888888"
                   HorizontalAlignment="Center"/>

        <ProgressBar x:Name="ProgressBar"
                     Maximum="100"
                     Width="280"
                     Height="4"
                     Foreground="#6c63ff"
                     Background="#2a2b3e"
                     IsIndeterminate="True"/>
    </StackPanel>

</Window>
