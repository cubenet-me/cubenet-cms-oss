package web

templ loginPage(data BaseData, err string) {
	@base(data) {
		<div class="max-w-5xl mx-auto px-4 py-16">
			<div class="bg-surface border border-border rounded-lg max-w-sm mx-auto p-8">
				<h1 class="text-2xl font-bold text-center mb-2">Вход</h1>
				<p class="text-sm text-surface-dimmed text-center mb-8">Войдите в панель управления</p>

				if err != "" {
					<div class="bg-red-950/40 border border-red-800/50 rounded-lg p-4 mb-4 text-sm">
						{ err }
					</div>
				}

				<form hx-post="/auth/login" hx-target="body" hx-swap="outerHTML" class="space-y-4">
					<div>
						<label class="block text-sm text-surface-dimmed mb-1" for="username">Имя пользователя</label>
						<input class="w-full px-3 py-2 bg-[oklch(14%_0.03_280deg)] border border-[oklch(30%_0.05_280deg)] rounded-lg text-sm text-white placeholder-surface-muted focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/20 transition-colors" type="text" id="username" name="username" required placeholder="Введите логин"/>
					</div>
					<div>
						<label class="block text-sm text-surface-dimmed mb-1" for="password">Пароль</label>
						<input class="w-full px-3 py-2 bg-[oklch(14%_0.03_280deg)] border border-[oklch(30%_0.05_280deg)] rounded-lg text-sm text-white placeholder-surface-muted focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/20 transition-colors" type="password" id="password" name="password" required placeholder="Введите пароль"/>
					</div>
					<button type="submit" class="inline-flex items-center justify-center w-full px-4 py-2 rounded-lg text-sm font-medium bg-accent text-white hover:bg-accent-hover transition-colors">Войти</button>
				</form>

				<p class="text-sm text-center mt-6 text-surface-dimmed">
					Нет аккаунта? <a href="/register" class="text-accent hover:underline">Зарегистрироваться</a>
				</p>
			</div>
		</div>
	}
}
