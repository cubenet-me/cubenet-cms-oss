package web

templ serversPage(data BaseData) {
	@base(data) {
		<div class="max-w-5xl mx-auto px-4 py-12">
			<h1 class="text-3xl font-bold mb-8">Серверы</h1>
			<div class="grid gap-4" id="server-list" hx-get="/api/v1/servers" hx-trigger="load" hx-swap="innerHTML">
				<div class="bg-surface border border-border rounded-lg p-6">Загрузка...</div>
			</div>
		</div>
	}
}
